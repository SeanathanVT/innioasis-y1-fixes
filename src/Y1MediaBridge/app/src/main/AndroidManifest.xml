<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="16"
    android:versionName="1.9">

    <!--
        READ_LOGS is signatureOrSystem on Android 4.2.
        Granted to apps installed in /system/app/ without platform signing.
    -->
    <uses-permission android:name="android.permission.READ_LOGS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.MEDIA_CONTENT_CONTROL" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!--
        WRITE_MEDIA_STORAGE is signatureOrSystem on Android 4.2 and grants
        AID_MEDIA_RW (1023) — the supplementary group that owns the actual
        file ACL on /storage/sdcard0 on this Y1 firmware. Without it,
        FileInputStream("/storage/sdcard0/Music/...") fails with EACCES
        (Permission denied) — confirmed in early hardware captures
        where every direct-read miss path errored out. READ_EXTERNAL_STORAGE
        was nominally added in API 16 but is not enforced as a positive grant
        on this 4.2 build; the file ACL is what gates open(2). Apps in
        /system/app/ get signatureOrSystem perms at install time without
        platform signing.
    -->
    <uses-permission android:name="android.permission.WRITE_MEDIA_STORAGE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:label="Y1 Media Bridge"
        android:allowBackup="false"
        android:persistent="true">

        <!--
            Service exposed under com.android.music.MediaPlaybackService.
            MtkBt.apk binds to this, then wraps the returned binder with both
            IBTAvrcpMusic.Stub.asInterface() and (legacy path) raw
            IMediaPlaybackService transactions. The binder dispatches by
            interface token in onTransact. Media buttons are delivered via
            PlaySongReceiver (registered at runtime through AudioManager).
        -->
        <service
            android:name=".MediaBridgeService"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.android.music.MediaPlaybackService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".PlaySongReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MY_PLAY_SONG" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.innioasis.y1.ABOUT_SHUT_DOWN" />
            </intent-filter>
            <!--
                MEDIA_BUTTON is received via AudioManager.registerMediaButton-
                EventReceiver in MediaBridgeService. The runtime registration
                is what actually wires us into the media button chain; this
                filter is here for manifest completeness.
            -->
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
